{
  "name": "rootguard",
  "version": "0.1.0",
  "description": "Guard command execution by verifying repo root identity and explicit command allowlists.",
  "type": "module",
  "main": "./dist/index.js",
  "bin": {
    "rootguard": "./bin/rootguard.js"
  },
  "exports": {
    ".": "./dist/index.js"
  },
  "files": [
    "bin",
    "dist",
    "docs",
    "README.md"
  ],
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check": "tsc -p tsconfig.json --noEmit",
    "test": "npm run build && node --test test/*.test.js",
    "smoke": "npm run build && bash scripts/smoke.sh",
    "prepack": "npm run build",
    "package:smoke": "npm pack --dry-run",
    "release:check": "npm run check && npm test && npm run smoke && npm run package:smoke"
  },
  "keywords": [
    "cli",
    "developer-tools",
    "worktrees",
    "safety",
    "local-first",
    "agentic-workflows"
  ],
  "author": "Roger Chappel",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/rogerchappel/rootguard.git"
  },
  "bugs": {
    "url": "https://github.com/rogerchappel/rootguard/issues"
  },
  "homepage": "https://github.com/rogerchappel/rootguard#readme",
  "engines": {
    "node": ">=20"
  },
  "devDependencies": {
    "@types/node": "^22.15.21",
    "typescript": "^5.8.3"
  }
}
